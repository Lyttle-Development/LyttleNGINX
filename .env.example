# Environment Configuration Example for LyttlenGinx Application
#
# This file is intentionally safe to commit.
# Do not place live secrets in this file or commit your local `.env` / `.env.*` overrides.
# For production, inject sensitive values through Docker Swarm secrets or an external secret store.

# ===============================================
# DATABASE CONFIGURATION (REQUIRED)
# ===============================================
DATABASE_URL="postgresql://lyttlenginx:<db-password>@localhost:5432/lyttlenginx?connect_timeout=360&pool_timeout=360&pool_size=1&schema=public&sslmode=no-verify"
# If you provide `pool_size`, the runtime will mirror it into Prisma's
# `connection_limit` setting automatically.

# ===============================================
# ADMIN CONFIGURATION (REQUIRED FOR PRODUCTION)
# ===============================================
# IMPORTANT: ADMIN_EMAIL is REQUIRED for Let's Encrypt certificate issuance
# Application will fail to start if not set in production
ADMIN_EMAIL="admin@example.com"

# ===============================================
# SECURITY (REQUIRED - INJECT THESE AT RUNTIME)
# ===============================================
# Generate strong secrets at deploy time, for example:
#   openssl rand -base64 32
# API_KEY supports multiple comma-separated keys.
# Keep the real value in a Swarm secret or external secret manager.
# Session 7 keeps API keys as a temporary compatibility bridge, but bearer tokens
# should become the default client credential format going forward.
API_KEY="<inject-runtime-secret>"

# JWT / bearer-token foundation.
# AUTH_JWT_SECRET enables locally signed HS256 access tokens (including
# `/auth/token` exchange from a legacy API key). For external identity providers,
# prefer AUTH_JWT_PUBLIC_KEY plus the expected issuer/audience below.
AUTH_JWT_SECRET="<inject-runtime-secret>"
# AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
AUTH_JWT_ISSUER="lyttle-nginx"
AUTH_JWT_AUDIENCE="lyttle-nginx-admin"
AUTH_JWT_ALLOWED_ALGS="HS256,RS256"
AUTH_ACCESS_TOKEN_TTL_SECONDS="900"

# Temporary default identity mapping for legacy API keys during the bearer-token migration.
# Supported RBAC roles are: viewer, operator, security-admin, platform-admin.
AUTH_DEFAULT_ADMIN_ROLES="platform-admin"
AUTH_DEFAULT_ADMIN_SCOPES="admin:full"

# ===============================================
# APPLICATION SETTINGS
# ===============================================
NODE_ENV="production"
PORT="3000"

# Restrict `nginx_custom_code` root/alias directives to approved static-content
# prefixes. Session 14 validates fragments against this allowlist before any
# staged config activation occurs.
NGINX_CUSTOM_CODE_ALLOWED_PATH_PREFIXES="/var/www,/srv/www,/etc/nginx/custom,/usr/share/nginx/html,/etc/nginx/html"

# ===============================================
# CLUSTER CONTROL-PLANE SETTINGS
# ===============================================
# Configure the host/address and port that peer nodes should use for inter-node
# control-plane traffic. Do not rely on public-IP autodiscovery.
#
# Single-node/local example:
#   CLUSTER_CONTROL_ADDRESS="app"
#   CLUSTER_CONTROL_PORT="3000"
#
# Swarm global-mode example with host-published admin port:
#   CLUSTER_CONTROL_ADDRESS="node-a.internal"
#   CLUSTER_CONTROL_PORT="3003"
#
# You may alternatively provide CLUSTER_CONTROL_URL="http://node-a.internal:3003"
# instead of the address/port pair.
CLUSTER_CONTROL_ADDRESS="node-a.internal"
CLUSTER_CONTROL_PORT="3003"
CLUSTER_CONTROL_PROTOCOL="http"

# Leader coordination lease tuning.
# Keep the TTL comfortably larger than the renew interval so transient delays do
# not cause avoidable leader loss.
CLUSTER_LEASE_TTL_SECONDS="30"
CLUSTER_LEASE_RENEW_INTERVAL_MS="10000"

# ===============================================
# CERTIFICATE MANAGEMENT SETTINGS
# ===============================================
# Days before expiry to trigger renewal (default: 30)
RENEW_BEFORE_DAYS="30"

# Days before expiry to send alerts (default: 14)
ALERT_THRESHOLD_DAYS="14"

# Use Let's Encrypt staging API for testing (optional)
# Set to "true" to avoid rate limits during testing
# LETSENCRYPT_STAGING="false"

# ACME challenge strategy selection.
# - auto   : use built-in HTTP-01 for normal domains, DNS-01 for wildcard orders
# - http-01: force the built-in database-backed HTTP-01 flow
# - dns-01 : force DNS-01 using operator-supplied manual hook scripts
ACME_CHALLENGE_STRATEGY="auto"

# Built-in HTTP-01 configuration.
# These default hook paths are baked into the container image; override only if you
# deliberately mount alternate hook implementations.
ACME_HTTP01_AUTH_HOOK="/certbot-auth-hook.sh"
ACME_HTTP01_CLEANUP_HOOK="/certbot-cleanup-hook.sh"
ACME_HTTP01_PROVIDER="database-http-01"
ACME_HTTP01_PROPAGATION_SECONDS="5"

# DNS-01 configuration.
# Wildcard orders require DNS-01. Mount provider-specific hook scripts into the
# container and point these settings at their absolute paths.
# Example provider label: route53-manual, cloudflare-manual, infoblox-manual
ACME_DNS_PROVIDER="route53-manual"
ACME_DNS_AUTH_HOOK="/opt/acme/dns-auth.sh"
ACME_DNS_CLEANUP_HOOK="/opt/acme/dns-cleanup.sh"
ACME_DNS_PROPAGATION_SECONDS="45"

# ===============================================
# EMAIL/SMTP CONFIGURATION (OPTIONAL - RECOMMENDED)
# ===============================================
# Configure SMTP for certificate expiry alerts
# Example for Gmail: smtp.gmail.com:587 with app password
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS="<inject-runtime-secret-or-leave-empty>"
ALERT_EMAIL=""
ALERT_FROM_EMAIL=""

# ===============================================
# ALERT WEBHOOKS (OPTIONAL - RECOMMENDED)
# ===============================================
# Slack webhook URL for alerts
SLACK_WEBHOOK_URL="<inject-runtime-secret-or-leave-empty>"

# Discord webhook URL for alerts
DISCORD_WEBHOOK_URL="<inject-runtime-secret-or-leave-empty>"

# ===============================================
# RATE LIMITING (OPTIONAL)
# ===============================================
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"

# ===============================================
# SECRET-HANDLING NOTES
# ===============================================
# - `.env.example` is the only env file intended to be tracked in git.
# - Keep real `.env`, `.env.production`, `.env.local`, and similar files out of version control.
# - Prefer Docker Swarm secrets, Vault, AWS Secrets Manager, GCP Secret Manager, or equivalent.
# - Until the application gains first-class *_FILE secret ingestion, inject runtime values from
#   your deployment system rather than committing them to the repository.
