{
  "name": "lyttle-nginx",
  "version": "0.0.1",
  "description": "NGINX proxy with database connection",
  "author": "lyttle-development",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "npm@11.15.0",
  "scripts": {
    "clean": "rm -rf dist coverage",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.js\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ./test/run-suite.js all",
    "test:all": "node ./test/run-suite.js all",
    "test:unit": "node ./test/run-suite.js unit",
    "test:integration": "node ./test/run-suite.js integration",
    "test:e2e": "node ./test/run-suite.js e2e",
    "test:chaos": "node ./test/run-suite.js chaos",
    "test:coverage": "node ./test/run-suite.js all --coverage",
    "test:list": "node ./test/run-suite.js --list",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:dangerously-db-push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name merge-upstream",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:ci": "eslint --max-warnings=0 --rule '{\"prettier/prettier\":\"off\"}' \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "docker:setup": "npm run prisma:generate && npm run build",
    "docker:build": "docker build -t lyttle-nginx .",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test:coverage:ci": "node ./scripts/ci/assert-coverage.js",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify:ci": "npm run prisma:generate && npm run lint:ci && npm run typecheck && npm run test:coverage:ci && npm run build && npm run audit:prod",
    "update": "npm update --save"
  },
  "volta": {
    "node": "24.16.0",
    "npm": "11.15.0"
  },
  "engines": {
    "node": "24.16.0",
    "npm": "11.15.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^7.8.0",
    "@promster/express": "^15.5.1",
    "@types/archiver": "^7.0.0",
    "@types/nodemailer": "^8.0.0",
    "acme-client": "^5.4.0",
    "archiver": "^8.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.3.0",
    "nodemailer": "^8.0.8",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "@prisma/streams-local": {
      "ajv": "8.20.0"
    },
    "fast-uri": "3.1.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.23",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
