generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProxyEntry {
  id                Int       @id @default(autoincrement())
  proxy_pass_host   String
  domains           String // semicolon-separated list
  nginx_custom_code String?
  type              ProxyType @default(PROXY)
  ssl               Boolean   @default(false)
}

enum ProxyType {
  REDIRECT
  PROXY
}

model Certificate {
  id            String    @id @default(uuid())
  domains       String // ';'-joined list of domains (e.g. "a.com;b.com")
  domainsHash   String // SHA256 hash of sorted split domains
  certPem       String // Certificate PEM
  keyPem        String // Private Key PEM
  expiresAt     DateTime
  issuedAt      DateTime
  lastUsedAt    DateTime
  isOrphaned    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  status        String    @default("active") // active, failed, pending
  failureReason String?
  retryAfter    DateTime?
  failureCount  Int       @default(0)
  issuedByNode  String?

  @@unique([domainsHash])
  @@index([domainsHash])
  @@index([retryAfter])
}

model ClusterNode {
  id            String   @id @default(uuid())
  hostname      String
  instanceId    String   @unique
  ipAddress     String? // Advertised control-plane host/address used for peer communication
  isLeader      Boolean  @default(false)
  lastHeartbeat DateTime
  version       String?
  status        String   @default("active") // active, inactive, failed
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isLeader, lastHeartbeat])
  @@index([hostname])
  @@index([ipAddress])
}

model ClusterLease {
  id            String   @id @default(uuid())
  leaseName     String   @unique
  ownerNodeId   String? // Currently stores the active instanceId until stable node IDs land in later sessions
  ownerHostname String?
  generation    Int      @default(1)
  ttlSeconds    Int      @default(30)
  acquiredAt    DateTime @default(now())
  renewedAt     DateTime @default(now())
  expiresAt     DateTime
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerNodeId])
  @@index([expiresAt])
  @@index([ownerNodeId, expiresAt])
}

model ClusterOperation {
  id                        String                @id @default(uuid())
  operationType             String
  scope                     String                @default("cluster")
  status                    String                @default("pending")
  initiatorNodeId           String?
  initiatorHostname         String?
  initiatorActorId          String?
  initiatorActorType        String?
  initiatorActorDisplayName String?
  correlationId             String?
  requestPath               String?
  targetNodeCount           Int                   @default(0)
  completedNodeCount        Int                   @default(0)
  successfulNodeCount       Int                   @default(0)
  failedNodeCount           Int                   @default(0)
  startedAt                 DateTime?
  completedAt               DateTime?
  lastError                 String?
  metadata                  Json?
  acknowledgements          ClusterOperationAck[]
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([operationType, createdAt])
  @@index([correlationId])
}

model ClusterOperationAck {
  id            String           @id @default(uuid())
  operationId   String
  nodeInstanceId String
  nodeHostname  String?
  endpointUrl   String?
  status        String           @default("pending")
  responseStatus Int?
  errorMessage  String?
  startedAt     DateTime?
  ackedAt       DateTime?
  details       Json?
  operation     ClusterOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([operationId, nodeInstanceId])
  @@index([status, ackedAt])
  @@index([nodeInstanceId, status])
}

model AcmeChallenge {
  id        String   @id @default(uuid())
  token     String   @unique // The challenge token (filename)
  keyAuth   String // The key authorization (file content)
  domain    String // Domain this challenge is for
  createdAt DateTime @default(now())
  expiresAt DateTime // Challenges expire after 1 hour

  @@index([token])
  @@index([domain])
  @@index([expiresAt])
}

model AuditEvent {
  id               String   @id @default(uuid())
  action           String
  targetType       String?
  targetId         String?
  targetDisplay    String?
  outcome          String
  result           String
  correlationId    String
  actorId          String?
  actorSubject     String?
  actorType        String?
  actorDisplayName String?
  actorAuthMethod  String?
  actorRoles       String?
  requestMethod    String
  requestPath      String
  responseStatus   Int
  nodeId           String?
  ipAddress        String?
  errorCode        String?
  errorMessage     String?
  metadata         Json?
  occurredAt       DateTime @default(now())

  @@index([occurredAt])
  @@index([action])
  @@index([outcome])
  @@index([actorSubject])
  @@index([correlationId])
}


